# =========================
# Runtime / Global
# =========================
TZ=Asia/Taipei
USER_AGENT=Mozilla/5.0 (compatible; bid-monitor/1.0; +https://example.com)
REQUEST_TIMEOUT_SECONDS=20
REQUEST_RETRY_TOTAL=3
REQUEST_BACKOFF_FACTOR=0.8
RECENT_DAYS=1
HIGH_AMOUNT_THRESHOLD=5000000
ENABLE_PLAYWRIGHT=false
PLAYWRIGHT_TIMEOUT_MS=20000

# =========================
# Data Sources
# =========================
TAIWANBUYING_URL=https://www.taiwanbuying.com.tw/
TAIWANBUYING_METHOD=GET
TAIWANBUYING_PARAMS_JSON={}
TAIWANBUYING_ROW_SELECTORS=table tbody tr,.list-group-item,.result-item,.news-list li
TAIWANBUYING_TITLE_SELECTORS=a,.title,.subject,td:nth-child(2)
TAIWANBUYING_ORG_SELECTORS=.org,.unit,.agency,td:nth-child(3)
TAIWANBUYING_DATE_SELECTORS=.date,.publish-date,time,td:nth-child(1)
TAIWANBUYING_AMOUNT_SELECTORS=.amount,.price,.money,td:nth-child(5)
TAIWANBUYING_SUMMARY_SELECTORS=.summary,.desc,.content,td:nth-child(4)
TAIWANBUYING_LINK_SELECTORS=a

GOV_URL=https://web.pcc.gov.tw/pis/
GOV_METHOD=GET
GOV_PARAMS_JSON={}
GOV_ROW_SELECTORS=table tbody tr,.list-group-item,.result-item,.row
GOV_TITLE_SELECTORS=a,.title,.subject,td:nth-child(2)
GOV_ORG_SELECTORS=.org,.unit,.agency,td:nth-child(3)
GOV_DATE_SELECTORS=.date,.publish-date,time,td:nth-child(1)
GOV_AMOUNT_SELECTORS=.amount,.price,.money,td:nth-child(5)
GOV_SUMMARY_SELECTORS=.summary,.desc,.content,td:nth-child(4)
GOV_LINK_SELECTORS=a

# OpenFun API (default source)
G0V_API_URL=https://pcc-api.openfun.app/api/listbydate
G0V_ENABLED=true
# 僅使用 OpenFun API（速度快，但資料通常延遲 1-4 天；要同日偵測請保持 false）
API_ONLY_MODE=false

# =========================
# State Storage (Table first, Blob fallback)
# =========================
AZURE_STORAGE_CONNECTION_STRING=
AZURE_TABLE_NAME=BidNotifyState
AZURE_BLOB_CONTAINER=bid-state
AZURE_BLOB_NAME=notified_state.json

# =========================
# Email recipients
# =========================
EMAIL_TO=user1@example.com,user2@example.com
EMAIL_SUBJECT_PREFIX=[教育資訊標案監控]

# =========================
# ACS Email (preferred)
# =========================
ACS_CONNECTION_STRING=
ACS_EMAIL_SENDER=

# =========================
# SMTP (fallback)
# =========================
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# =========================
# Local mode
# =========================
DRY_RUN=false
PREVIEW_HTML_PATH=

# =========================
# AI Classification (optional)
# =========================
# 啟用 AI 分類功能（true/false）
ENABLE_AI_CLASSIFICATION=false
# OpenAI API Key（優先使用）
OPENAI_API_KEY=
# Anthropic API Key（OpenAI 不可用時使用）
ANTHROPIC_API_KEY=
# 指定模型（留空使用預設：OpenAI=gpt-4o-mini, Anthropic=claude-sonnet-4-20250514）
AI_MODEL=

# =========================
# Embedding Semantic Recall（Phase 2 語意召回）推薦啟用
# =========================
# 啟用 embedding 語意相似度召回（true/false）
ENABLE_EMBEDDING_RECALL=true
# Sentence-transformers 模型名稱（推薦 BAAI/bge-m3：繁中優秀、8192 tokens、hybrid search 原生支援）
EMBEDDING_MODEL=BAAI/bge-m3
# 召回前 K 個候選（建議範圍 20-40）
EMBEDDING_TOP_K=30
# 最低相似度閾值（0.0-1.0；bge-m3 建議 0.65-0.72）
EMBEDDING_SIMILARITY_THRESHOLD=0.68

# =========================
# Local LLM（Phase 3 深度驗證，Ollama）暫時停用
# =========================
# 當前推薦使用 Hybrid Search (Keyword + Embedding) 即可
# 如需啟用 Local LLM，請參考 LOCAL_LLM_QUICK_START.md

# Ollama API 端點（留空則不使用 Ollama）
OLLAMA_BASE_URL=
# 使用的模型（推薦：qwen2.5:3b 輕量版）
# OLLAMA_MODEL=qwen2.5:3b
# Ollama 推理超時時間（秒）
# OLLAMA_TIMEOUT_SECONDS=90
# 使用驗證模式（僅驗證+評分，不生成摘要）
# USE_VALIDATION_MODE=true

# =========================
# GitHub Issue Tracking (optional)
# =========================
# 高優先度標案自動建立 GitHub Issue
GITHUB_TOKEN=
GITHUB_REPO=aaron-ren2021/webpccscrape
GITHUB_LABELS=bid-tracking
